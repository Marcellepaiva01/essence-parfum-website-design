# Copie este arquivo para .env e preencha com os valores do seu projeto Supabase.
# NUNCA commite o arquivo .env com chaves reais.

# URL do projeto (Settings → API → Project URL)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave pública / anon (Settings → API → anon public ou publishable key)
# Segura para uso no frontend — nunca use service_role aqui.
VITE_SUPABASE_ANON_KEY=sua_chave_anon_ou_publishable_aqui
