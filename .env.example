# Copie este arquivo para .env e preencha com os valores do seu projeto Supabase.
# NUNCA commite o arquivo .env com chaves reais.

# URL do projeto (Settings → API → Project URL)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anon legada (Settings → API → anon public)
# Nota: chaves publishable (sb_publishable_*) podem não funcionar com Auth ainda.
VITE_SUPABASE_ANON_KEY=sua_chave_anon_jwt_aqui
